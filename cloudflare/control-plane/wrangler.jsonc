{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "assistant-mk1-dev-control-plane",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_als"],
  "vars": {
    "LANGGRAPH_UPSTREAM_URL": "https://assistant-mk1-langgraph-dev.fly.dev",
    "OPENROUTER_MODEL": "deepseek/deepseek-v4-flash",
    "OPENROUTER_SITE_URL": "https://assistant-mk1.vercel.app",
    "OPENROUTER_APP_NAME": "assistant-mk1-cloudflare-chat",
    "SENTRY_ENVIRONMENT": "production",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "assistant_mk1_dev",
      "database_id": "1b5ba1b2-e19e-4db4-825b-d911b1ddf9db",
    },
  ],
}
