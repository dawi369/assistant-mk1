{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "assistant-mk1-dev-control-plane",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat", "nodejs_als"],
  "vars": {
    "LANGGRAPH_UPSTREAM_URL": "https://assistant-mk1-langgraph-dev.fly.dev",
    "LANGGRAPH_ASSISTANT_ID": "agent",
    "OPENROUTER_MODEL": "deepseek/deepseek-v4-flash",
    "OPENROUTER_SITE_URL": "https://assistant-mk1.vercel.app",
    "OPENROUTER_APP_NAME": "assistant-mk1-cloudflare-chat",
    "WORKBENCH_CALLBACK_URL": "https://assistant-mk1-dev-control-plane.david-erwin-cz68.workers.dev/workbench/run-callbacks",
    "SENTRY_ENVIRONMENT": "production",
    "SENTRY_TRACES_SAMPLE_RATE": "0.02",
  },
  "triggers": {
    "crons": ["* * * * *"],
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "assistant_mk1_dev",
      "database_id": "1b5ba1b2-e19e-4db4-825b-d911b1ddf9db",
      "migrations_dir": "migrations",
      "migrations_table": "d1_migrations",
    },
  ],
  "r2_buckets": [
    {
      "binding": "ARTIFACTS",
      "bucket_name": "assistant-mk1-dev-artifacts",
      "preview_bucket_name": "assistant-mk1-local-artifacts",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "WorkbenchThreadChatAgent",
        "class_name": "WorkbenchThreadChatAgent",
      },
      {
        "name": "WorkbenchSessionAgent",
        "class_name": "WorkbenchSessionAgent",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1-workbench-thread-chat-agent",
      "new_sqlite_classes": ["WorkbenchThreadChatAgent"],
    },
    {
      "tag": "v2-workbench-session-agent",
      "new_sqlite_classes": ["WorkbenchSessionAgent"],
    },
  ],
}
