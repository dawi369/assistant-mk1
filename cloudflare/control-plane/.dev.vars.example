# Copy to .dev.vars for local Worker development. Never commit real values.
CLOUDFLARE_CONTROL_PLANE_DEV_TOKEN=replace-with-a-local-token
OPENROUTER_API_KEY=
LANGGRAPH_UPSTREAM_URL=http://127.0.0.1:2024
LANGGRAPH_UPSTREAM_TOKEN=replace-with-the-local-langgraph-token
WORKBENCH_AGENT_CONNECTION_SECRET=replace-with-a-long-random-secret
WORKBENCH_EXECUTOR_URL=http://localhost:3000/api/workbench/executors/demo-inspect
WORKBENCH_EXECUTOR_TOKEN=replace-with-the-local-executor-token
WORKBENCH_CALLBACK_SIGNING_SECRET=replace-with-a-long-random-secret

# Optional Fly runner path. Inline Cloudflare execution remains the default.
WORKBENCH_RUNNER_TRANSPORT=inline
WORKBENCH_RUNNER_URL=
WORKBENCH_RUNNER_SIGNING_SECRET=

# Optional signed operator alert delivery. Configure both or neither.
WORKBENCH_OPERATOR_ALERT_WEBHOOK_URL=
WORKBENCH_OPERATOR_ALERT_SIGNING_SECRET=

# Local development accepts the bearer token above when facade signing is absent.
CLOUDFLARE_CONTROL_PLANE_REQUIRE_FACADE_SIGNATURE=false
ALLOWED_ORIGINS=http://localhost:3000
