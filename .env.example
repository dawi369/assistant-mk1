# Backend (LangGraph server)
OPENROUTER_API_KEY=
# Optional override; defaults to openai/gpt-5.2
OPENROUTER_MODEL=
# Optional OpenRouter attribution metadata
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=assistant-mk1

# LangSmith tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=assistant-mk1

# Sentry error monitoring and traces.
# One Sentry project is used for all assistant-mk1 runtime surfaces; filter by
# runtime.surface in Sentry:
# - vercel-next
# - cloudflare-worker
# - fly-langgraph (future)
SENTRY_ORG=t23
SENTRY_PROJECT=assistant-mk1
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Development defaults to full tracing; production should usually stay low-noise.
SENTRY_TRACES_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
# Optional. Used by Sentry source map upload during CI/build; keep secret.
SENTRY_AUTH_TOKEN=

# Frontend (Next.js proxy to LangGraph or the Cloudflare LangGraph facade).
# Local default points directly at LangGraph. Hosted dev points at:
# https://<worker-url>/langgraph
LANGGRAPH_API_URL=http://localhost:2024
# Forwarded as `x-api-key` only when CLOUDFLARE_CONTROL_PLANE_DEV_TOKEN is not
# set. In hosted dev, Cloudflare stores the Fly gateway token instead.
LANGCHAIN_API_KEY=
# Graph id. Must match a key under "graphs" in langgraph.json.
NEXT_PUBLIC_LANGGRAPH_ASSISTANT_ID=agent
# Optional. Bypasses the /api proxy and lets the browser hit LangGraph directly.
# Leave unset to route everything through the Next.js proxy on the current host.
NEXT_PUBLIC_LANGGRAPH_API_URL=

# WorkOS AuthKit. Server-side secrets stay out of NEXT_PUBLIC_*.
# Configure matching redirect/sign-out URLs in the WorkOS dashboard.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# 32+ chars. Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=
# Local: http://localhost:3000/auth/callback
# Production: https://assistant-mk1.vercel.app/auth/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Comma-separated list of allowed CORS origins. When unset, no Access-Control-
# Allow-Origin header is sent (same-origin only). Set to "*" to allow all
# origins (not recommended for production).
ALLOWED_ORIGINS=http://localhost:3000

# External signal ingress. Required before POST /api/external-signals will run.
EXTERNAL_SIGNAL_TOKEN=

# Cloudflare-owned workbench run path.
CLOUDFLARE_CONTROL_PLANE_URL=http://localhost:8787
# Must match cloudflare/control-plane/.dev.vars for local Vercel -> Worker calls.
CLOUDFLARE_CONTROL_PLANE_DEV_TOKEN=
# Must match cloudflare/control-plane/.dev.vars for local demo.inspect callbacks.
WORKBENCH_EXECUTOR_TOKEN=

# Local fallback identity when WorkOS is not configured. Server-side only;
# browsers do not set tenant scope or agent identity directly. Hosted WorkOS
# traffic resolves the active agent from Cloudflare D1 instead.
WORKBENCH_DEV_USER_ID=dev-user
WORKBENCH_DEV_WORKSPACE_ID=dev-workspace
WORKBENCH_DEV_AGENT_ID=dev-agent
