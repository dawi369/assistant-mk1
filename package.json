{
  "name": "assistant-mk1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "next dev --turbopack",
    "dev:backend": "langgraphjs dev --host 0.0.0.0 --port 2024 --no-browser",
    "build": "next build",
    "start": "next start",
    "start:frontend": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "start:backend": "langgraphjs dev --host 0.0.0.0 --port ${LANGGRAPH_PORT:-2024} --no-browser",
    "start:fly": "concurrently -n frontend,backend -c cyan,magenta \"pnpm start:frontend\" \"pnpm start:backend\"",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint && oxfmt --check",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint:fix": "oxlint --fix && oxfmt"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.11",
    "@assistant-ui/react-langgraph": "latest",
    "@assistant-ui/react-markdown": "^0.14.1",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/langgraph-sdk": "^1.9.6",
    "@langchain/openrouter": "^0.3.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.11",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph-cli": "^1.2.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tailwindcss": "^4.3.0",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.0"
}
