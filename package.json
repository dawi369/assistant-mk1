{
  "name": "assistant-mk1",
  "version": "1.0.0-preview.1",
  "private": true,
  "description": "Code-first agent workbench for durable runs, approvals, policy, artifacts, audit, and tenant-safe operations.",
  "homepage": "https://github.com/dawi369/assistant-mk1#readme",
  "bugs": {
    "url": "https://github.com/dawi369/assistant-mk1/issues"
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dawi369/assistant-mk1.git"
  },
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:workbench": "concurrently -n frontend,backend,cloudflare -c cyan,magenta,yellow \"pnpm dev:frontend\" \"pnpm dev:backend\" \"pnpm dev:cloudflare\"",
    "dev:frontend": "next dev --turbopack",
    "dev:backend": "langgraphjs dev --host 0.0.0.0 --port 2024 --no-browser",
    "build": "next build",
    "start": "next start",
    "start:backend": "langgraphjs dev --host 0.0.0.0 --port ${LANGGRAPH_PORT:-2024} --no-browser",
    "start:langgraph-gateway": "tsx scripts/langgraph-runtime-gateway.ts",
    "start:langgraph-runtime": "concurrently -n gateway,langgraph -c cyan,magenta \"pnpm start:langgraph-gateway\" \"pnpm start:backend\"",
    "test:unit": "vitest run",
    "eval:real-session-posture": "tsx scripts/eval-real-session-posture.ts",
    "conformance:level2": "tsx scripts/run-level2-conformance.ts",
    "conformance:level3": "tsx scripts/run-level3-conformance.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint && oxfmt --check",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint:fix": "oxlint --fix && oxfmt",
    "e2e:seed": "tsx scripts/reset-playwright-state.ts && wrangler d1 execute assistant_mk1_dev --local --persist-to output/playwright/state --file cloudflare/control-plane/schema.sql --config cloudflare/control-plane/wrangler.jsonc --yes && wrangler d1 execute assistant_mk1_dev --local --persist-to output/playwright/state --file tests/e2e/workbench-seed.sql --config cloudflare/control-plane/wrangler.jsonc --yes",
    "e2e:serve:runner": "PORT=3101 WORKBENCH_E2E_MODE=true WORKBENCH_E2E_RUNNER_DELAY_MS=${WORKBENCH_E2E_RUNNER_DELAY_MS:-0} WORKBENCH_RUNNER_SIGNING_SECRET=e2e-runner-signing-secret-00000001 WORKBENCH_CALLBACK_SIGNING_SECRET=e2e-callback-signing-secret-000001 WORKBENCH_RUNNER_CALLBACK_URL=http://127.0.0.1:8788 tsx scripts/run-with-log.ts output/playwright/runner.log pnpm start:langgraph-gateway",
    "e2e:serve:worker": "pnpm e2e:seed && tsx scripts/run-with-log.ts output/playwright/worker.log wrangler dev --config cloudflare/control-plane/wrangler.jsonc --local --persist-to output/playwright/state --port 8788 --var ALLOWED_ORIGINS:http://localhost:3100 --var CLOUDFLARE_CONTROL_PLANE_DEV_TOKEN:e2e-control-plane-token --var CLOUDFLARE_CONTROL_PLANE_FACADE_SIGNING_SECRET:e2e-facade-signing-secret-000001 --var CLOUDFLARE_CONTROL_PLANE_REQUIRE_FACADE_SIGNATURE:false --var WORKBENCH_AGENT_CONNECTION_SECRET:e2e-agent-connection-secret-000001 --var WORKBENCH_CALLBACK_SIGNING_SECRET:e2e-callback-signing-secret-000001 --var WORKBENCH_CALLBACK_URL:http://127.0.0.1:8788/workbench/run-callbacks --var WORKBENCH_RUNNER_TRANSPORT:fly --var WORKBENCH_RUNNER_URL:http://127.0.0.1:3101/workbench/tool-runners/invocations --var WORKBENCH_RUNNER_SIGNING_SECRET:e2e-runner-signing-secret-00000001",
    "test:e2e:signed-out": "E2E_RELEASE_MODE=signed-out playwright test",
    "test:e2e:local:release": "WORKBENCH_E2E_RUNNER_DELAY_MS=0 E2E_RELEASE_MODE=local-session playwright test tests/e2e/release.spec.ts",
    "test:e2e:local": "pnpm test:e2e:local:release && pnpm test:service-boundaries",
    "test:e2e": "pnpm test:e2e:signed-out && pnpm test:e2e:local",
    "test:service-boundaries:level2": "WORKBENCH_E2E_RUNNER_DELAY_MS=1500 E2E_RELEASE_MODE=local-session playwright test tests/e2e/level2-conformance.spec.ts",
    "test:service-boundaries:level3": "WORKBENCH_E2E_RUNNER_DELAY_MS=1500 E2E_RELEASE_MODE=local-session playwright test tests/e2e/level3-conformance.spec.ts",
    "test:service-boundaries": "pnpm test:service-boundaries:level2 && pnpm test:service-boundaries:level3",
    "docs:check": "tsx scripts/check-doc-links.ts",
    "workbench:doctor": "tsx scripts/workbench-doctor.ts",
    "acceptance:hosted:public": "tsx scripts/accept-hosted-public.ts",
    "verify:security": "pnpm audit --audit-level high",
    "verify:docker": "tsx scripts/verify-docker-image.ts",
    "verify:fast": "pnpm docs:check && pnpm agent-packs:validate && pnpm db:cloudflare:migrations:verify && pnpm test:unit && pnpm typecheck && pnpm lint",
    "verify": "pnpm verify:fast && pnpm verify:security && pnpm build",
    "release:check": "pnpm verify && pnpm verify:docker && pnpm conformance:level2 && pnpm conformance:level3",
    "agent-packs:validate": "tsx scripts/agent-packs-validate.ts",
    "agent-packs:inspect": "tsx scripts/agent-packs-inspect.ts",
    "agent-packs:smoke": "tsx scripts/agent-packs-smoke.ts",
    "db:cloudflare:rebuild:local": "wrangler d1 execute assistant_mk1_dev --local --file cloudflare/control-plane/schema.sql --config cloudflare/control-plane/wrangler.jsonc",
    "db:cloudflare:rebuild:remote": "wrangler d1 execute assistant_mk1_dev --remote --file cloudflare/control-plane/schema.sql --config cloudflare/control-plane/wrangler.jsonc",
    "db:cloudflare:migrate:local": "wrangler d1 migrations apply assistant_mk1_dev --local --config cloudflare/control-plane/wrangler.jsonc",
    "db:cloudflare:migrate:remote": "wrangler d1 migrations apply assistant_mk1_dev --remote --config cloudflare/control-plane/wrangler.jsonc",
    "db:cloudflare:migrations:verify": "tsx scripts/verify-d1-migrations.ts",
    "deploy:cloudflare": "wrangler deploy --config cloudflare/control-plane/wrangler.jsonc",
    "dev:cloudflare": "wrangler dev --config cloudflare/control-plane/wrangler.jsonc --local --port 8787",
    "deploy:fly:langgraph": "fly deploy --config fly.langgraph.toml --app assistant-mk1-langgraph-dev",
    "smoke:langgraph-runtime": "tsx scripts/smoke-langgraph-runtime.ts",
    "smoke:cloudflare-authz": "tsx scripts/smoke-cloudflare-authz.ts",
    "smoke:cloudflare-workspace-context": "tsx scripts/smoke-cloudflare-workspace-context.ts",
    "smoke:cloudflare-workspaces": "tsx scripts/smoke-cloudflare-workspaces.ts",
    "smoke:cloudflare-membership-policy": "tsx scripts/smoke-cloudflare-membership-policy.ts",
    "smoke:cloudflare-agent-selection": "tsx scripts/smoke-cloudflare-agent-selection.ts",
    "smoke:cloudflare-agent-provisioning": "tsx scripts/smoke-cloudflare-agent-provisioning.ts",
    "smoke:cloudflare-agent-behavior": "tsx scripts/smoke-cloudflare-agent-behavior.ts",
    "smoke:cloudflare-agent-runtime-config": "tsx scripts/smoke-cloudflare-agent-runtime-config.ts",
    "smoke:cloudflare-agent-chat": "tsx scripts/smoke-cloudflare-agent-chat.ts",
    "smoke:cloudflare-agent-chat-auth": "tsx scripts/smoke-cloudflare-agent-chat-auth.ts",
    "smoke:cloudflare-admin-summary": "tsx scripts/smoke-cloudflare-admin-summary.ts",
    "smoke:cloudflare-signed-facade": "tsx scripts/smoke-cloudflare-signed-facade.ts",
    "smoke:cloudflare-tool-admin": "tsx scripts/smoke-cloudflare-tool-admin.ts",
    "smoke:cloudflare-runtime-traces": "tsx scripts/smoke-cloudflare-runtime-traces.ts",
    "smoke:cloudflare-chat-runtime-summary": "tsx scripts/smoke-cloudflare-chat-runtime-summary.ts",
    "smoke:cloudflare-chat-reset": "tsx scripts/smoke-cloudflare-chat-reset.ts",
    "smoke:cloudflare-chat-session": "tsx scripts/smoke-cloudflare-chat-session.ts",
    "smoke:cloudflare-chat-session-lifecycle": "tsx scripts/smoke-cloudflare-chat-session-lifecycle.ts",
    "smoke:cloudflare-session-events": "tsx scripts/smoke-cloudflare-session-events.ts",
    "smoke:cloudflare-chat-threads": "tsx scripts/smoke-cloudflare-chat-threads.ts",
    "smoke:cloudflare-history": "tsx scripts/smoke-cloudflare-history.ts",
    "smoke:polymarket-readonly": "tsx scripts/smoke-polymarket-readonly.ts",
    "smoke:swordfish-readonly": "tsx scripts/smoke-swordfish-readonly.ts",
    "smoke:cloudflare-workbench-run": "tsx scripts/smoke-cloudflare-workbench-run.ts",
    "smoke:cloudflare-workflow-callback-auth": "tsx scripts/smoke-cloudflare-workflow-callback-auth.ts",
    "smoke:cloudflare-langgraph-facade": "tsx scripts/smoke-cloudflare-langgraph-facade.ts",
    "smoke:cloudflare-chat-boundary": "tsx scripts/smoke-cloudflare-chat-boundary.ts",
    "smoke:cloudflare-session-boundary": "tsx scripts/smoke-cloudflare-session-boundary.ts",
    "smoke:cloudflare-policy-boundary": "tsx scripts/smoke-cloudflare-policy-boundary.ts",
    "smoke:cloudflare-event-feed": "tsx scripts/smoke-cloudflare-event-feed.ts",
    "smoke:cloudflare-event-stream": "tsx scripts/smoke-cloudflare-event-stream.ts",
    "smoke:cloudflare-deploy-readiness": "pnpm smoke:cloudflare-signed-facade && pnpm smoke:cloudflare-workspace-context && pnpm smoke:cloudflare-tool-admin && pnpm smoke:cloudflare-policy-boundary && pnpm smoke:cloudflare-session-boundary && pnpm smoke:cloudflare-event-stream",
    "smoke:fly-tool-runner": "tsx scripts/smoke-fly-tool-runner.ts",
    "smoke:tenant-isolation": "tsx scripts/smoke-tenant-isolation.ts",
    "smoke:tool-registry": "tsx scripts/smoke-tool-registry.ts",
    "smoke:workbench": "tsx scripts/smoke-cloudflare-owned-run.ts"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.24",
    "@assistant-ui/react-ai-sdk": "^1.3.38",
    "@assistant-ui/react-markdown": "^0.14.1",
    "@cloudflare/ai-chat": "0.8.6",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/langgraph-cli": "^1.2.3",
    "@langchain/langgraph-sdk": "^1.9.6",
    "@langchain/openrouter": "^0.3.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/cloudflare": "^10.55.0",
    "@sentry/nextjs": "^10.55.0",
    "@workos-inc/authkit-nextjs": "^4.1.1",
    "agents": "0.16.0",
    "ai": "^6.0.208",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "croner": "10.0.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.11",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tailwindcss": "^4.3.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.33.0 <11"
  },
  "packageManager": "pnpm@10.33.0"
}
