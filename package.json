{
  "name": "assistant-mk1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "next dev --turbopack",
    "dev:backend": "langgraphjs dev --host 0.0.0.0 --port 2024 --no-browser",
    "build": "next build",
    "start": "next start",
    "start:backend": "langgraphjs dev --host 0.0.0.0 --port ${LANGGRAPH_PORT:-2024} --no-browser",
    "start:langgraph-gateway": "tsx scripts/langgraph-runtime-gateway.ts",
    "start:langgraph-runtime": "concurrently -n gateway,langgraph -c cyan,magenta \"pnpm start:langgraph-gateway\" \"pnpm start:backend\"",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint && oxfmt --check",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint:fix": "oxlint --fix && oxfmt",
    "db:cloudflare:rebuild:local": "wrangler d1 execute assistant_mk1_dev --local --file cloudflare/control-plane/schema.sql --config cloudflare/control-plane/wrangler.jsonc",
    "db:cloudflare:rebuild:remote": "wrangler d1 execute assistant_mk1_dev --remote --file cloudflare/control-plane/schema.sql --config cloudflare/control-plane/wrangler.jsonc",
    "deploy:cloudflare": "wrangler deploy --config cloudflare/control-plane/wrangler.jsonc",
    "dev:cloudflare": "wrangler dev --config cloudflare/control-plane/wrangler.jsonc --local --port 8787",
    "deploy:fly:langgraph": "fly deploy --config fly.langgraph.toml --app assistant-mk1-langgraph-dev",
    "smoke:langgraph-runtime": "tsx scripts/smoke-langgraph-runtime.ts",
    "smoke:cloudflare-langgraph-facade": "tsx scripts/smoke-cloudflare-langgraph-facade.ts",
    "smoke:cloudflare-chat-boundary": "tsx scripts/smoke-cloudflare-chat-boundary.ts",
    "smoke:cloudflare-session-boundary": "tsx scripts/smoke-cloudflare-session-boundary.ts",
    "smoke:cloudflare-policy-boundary": "tsx scripts/smoke-cloudflare-policy-boundary.ts",
    "smoke:tenant-isolation": "tsx scripts/smoke-tenant-isolation.ts",
    "smoke:tool-registry": "tsx scripts/smoke-tool-registry.ts",
    "smoke:workbench": "tsx scripts/smoke-cloudflare-owned-run.ts"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.11",
    "@assistant-ui/react-langgraph": "latest",
    "@assistant-ui/react-markdown": "^0.14.1",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/langgraph-sdk": "^1.9.6",
    "@langchain/openrouter": "^0.3.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.11",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph-cli": "^1.2.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "5.9.3",
    "wrangler": "^4.96.0"
  },
  "packageManager": "pnpm@10.33.0"
}
